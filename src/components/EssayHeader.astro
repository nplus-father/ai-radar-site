---
import BookCard from './BookCard.astro';
import type { EssayBook } from '../lib/library';

interface Props {
  data: {
    title: string;
    date: Date;
    model?: string;
    news?: { title: string; url: string; source?: string; summary?: string };
    books?: EssayBook[];
  };
}
const { data } = Astro.props;
const day = data.date.toISOString().slice(0, 10);
const books = data.books ?? [];
// Only attribute a real outlet (e.g. "Guardian"); the generic "news" source
// type is noise, so it is dropped rather than shown as "(news)".
const src = data.news?.source?.trim();
const outlet = src && !['news', 'rss', ''].includes(src.toLowerCase())
  ? src.charAt(0).toUpperCase() + src.slice(1)
  : null;
// Essays written before the model was recorded fall back to the generic
// attribution rather than claiming a model we cannot verify.
const model = data.model?.trim();
const byline = model ? `Written by ${model}` : 'AI-written';
---

<header class="essay-header">
  {
    data.news && (
      <p class="news-response">
        <span class="triplet-label">In response to the news</span>
        <a href={data.news.url} target="_blank" rel="noopener noreferrer">
          {data.news.title}
        </a>
        {outlet && <span class="news-source">({outlet})</span>}
      </p>
    )
  }

  <h1>{data.title}</h1>
  <p class="essay-meta">{day} · {byline}, reviewed by judge + critic</p>

  {data.news?.summary && <blockquote class="news-summary">{data.news.summary}</blockquote>}

  {
    books.length > 0 && (
      <div class="books-cited">
        <span class="triplet-label">Books cited</span>
        <div class="book-list">
          {books.map((b) => (
            <BookCard book={b} />
          ))}
        </div>
      </div>
    )
  }
</header>
