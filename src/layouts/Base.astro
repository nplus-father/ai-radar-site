---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Bookshelf Echo — reading the day’s news from the shelf' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style is:global>
      :root {
        --bg: #ffffff;
        --fg: #1a1a1a;
        --muted: #6b7280;
        --accent: #2563eb;
        --border: #e5e7eb;
        --card: #f9fafb;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0f1115;
          --fg: #e6e6e6;
          --muted: #9ca3af;
          --accent: #6ea8fe;
          --border: #262b36;
          --card: #161a22;
        }
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font: 16px/1.7 -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans TC', Roboto, sans-serif;
      }
      main { max-width: 720px; margin: 0 auto; padding: 2rem 1.25rem 4rem; }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      h1 { font-size: 2rem; line-height: 1.25; margin: 0 0 .3rem; letter-spacing: -0.01em; }
      h2 { margin-top: 2.4rem; font-size: 1.3rem; }
      h3 { margin-top: 1.6rem; line-height: 1.4; }
      code { background: var(--card); padding: .1em .35em; border-radius: 4px; font-size: .9em; }

      /* ---- site chrome ---- */
      header.site { border-bottom: 1px solid var(--border); margin-bottom: 2rem; padding-bottom: 1rem; }
      header.site .brand { font-weight: 700; font-size: 1.1rem; color: var(--fg); }
      header.site .tagline { color: var(--muted); margin: .25rem 0 .75rem; font-size: .95rem; }
      header.site nav { display: flex; gap: 1.25rem; font-size: .9rem; }
      header.site nav a { color: var(--muted); }
      header.site nav a.active { color: var(--fg); font-weight: 600; }
      footer { margin-top: 3.5rem; padding-top: 1rem; border-top: 1px solid var(--border); color: var(--muted); font-size: .85rem; }
      footer a { color: var(--muted); text-decoration: underline; }
      footer .dash-link { display: inline-block; margin-bottom: .5rem; }

      /* ---- reading column (essay prose) ---- */
      article {
        font-family: 'Noto Serif TC', Georgia, 'Songti TC', 'Times New Roman', serif;
        font-size: 1.075rem;
        line-height: 1.85;
      }
      article :is(p, li) { max-width: 38em; }
      article img { max-width: 100%; }
      article h2, article h3 { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans TC', sans-serif; }

      /* ---- essay triplet header ---- */
      .essay-header { border-bottom: 1px solid var(--border); padding-bottom: 1.5rem; margin-bottom: 2rem; }
      .triplet-label {
        display: block; text-transform: uppercase; letter-spacing: .08em;
        font-size: .72rem; color: var(--muted); margin-bottom: .3rem;
      }
      .news-response { margin: 0 0 1.25rem; line-height: 1.5; }
      .news-response a { font-weight: 600; }
      .news-source { color: var(--muted); font-size: .9rem; margin-left: .35rem; }
      .essay-meta { color: var(--muted); font-size: .85rem; margin: 0 0 1.25rem; }
      .news-summary {
        margin: 0 0 1.5rem; padding: .75rem 1rem; border-left: 3px solid var(--accent);
        background: var(--card); border-radius: 0 6px 6px 0; color: var(--fg);
        font-size: .95rem; line-height: 1.65;
      }
      .books-cited { margin-top: 1.25rem; }

      /* ---- book cards ---- */
      .book-list { display: flex; flex-wrap: wrap; gap: 1rem; }
      .book-card { display: flex; gap: .75rem; align-items: flex-start; max-width: 320px; }
      .book-cover-link { flex: none; line-height: 0; }
      .book-cover {
        width: 52px; height: auto; border-radius: 4px; border: 1px solid var(--border);
        box-shadow: 0 1px 4px rgba(0,0,0,.15);
      }
      .book-meta { display: flex; flex-direction: column; gap: .1rem; padding-top: .1rem; }
      .book-title { font-weight: 600; color: var(--fg); line-height: 1.35; }
      a.book-title:hover { color: var(--accent); }
      .book-chapter { color: var(--muted); font-size: .85rem; }

      /* ---- news digest ---- */
      .section-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; border-bottom: 1px solid var(--border); }
      .section-head h2 { margin: 0; padding-bottom: .3rem; }
      .digest-date { color: var(--muted); font-size: .85rem; white-space: nowrap; }
      .digest-list { list-style: none; padding: 0; margin: 1rem 0 0; }
      .digest-list > li { padding: .85rem 0; border-bottom: 1px solid var(--border); }
      .digest-list > li > a { font-weight: 600; }
      .digest-summary { margin: .35rem 0 0; color: var(--muted); font-size: .92rem; line-height: 1.6; }
      .digest-also { margin-top: 1rem; font-size: .9rem; }
      .digest-also summary { color: var(--muted); cursor: pointer; }
      .digest-also ul { margin: .5rem 0 0; padding-left: 1.1rem; }
      .digest-also li { padding: .2rem 0; }

      /* ---- index / archive lists ---- */
      ul.index { list-style: none; padding: 0; }
      ul.index li { padding: .55rem 0; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; gap: 1rem; }
      ul.index li span { color: var(--muted); white-space: nowrap; }
      .archive-list { list-style: none; padding: 0; margin: 1.5rem 0 0; }
      .archive-item { padding: 1rem 0; border-bottom: 1px solid var(--border); }
      .archive-item .a-date { color: var(--muted); font-size: .82rem; }
      .archive-item .a-title { display: block; font-weight: 600; font-size: 1.1rem; margin: .15rem 0; color: var(--fg); }
      .archive-item .a-title:hover { color: var(--accent); }
      .archive-item .a-meta { color: var(--muted); font-size: .88rem; line-height: 1.5; }
      .archive-item .a-meta a { color: var(--muted); text-decoration: underline; }

      /* ---- books index ---- */
      .book-index { display: grid; gap: 1.75rem; margin: 1.5rem 0 0; padding: 0; list-style: none; }
      .book-index > li { display: flex; gap: 1rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
      .book-index .bi-cover { width: 72px; height: auto; border-radius: 5px; border: 1px solid var(--border); box-shadow: 0 1px 5px rgba(0,0,0,.18); flex: none; }
      .book-index .bi-body { flex: 1; min-width: 0; }
      .book-index .bi-title { font-size: 1.1rem; font-weight: 700; color: var(--fg); }
      .book-index a.bi-title:hover { color: var(--accent); }
      .book-index .bi-essays { list-style: none; padding: 0; margin: .5rem 0 0; }
      .book-index .bi-essays li { padding: .2rem 0; font-size: .92rem; }
      .book-index .bi-essays .e-date { color: var(--muted); margin-right: .5rem; }

      .prev-next { display: flex; justify-content: space-between; gap: 1rem; margin-top: 2.5rem; font-size: .9rem; }
      .back { color: var(--muted); font-size: .9rem; }
    </style>
  </head>
  <body>
    <main>
      <header class="site">
        <a class="brand" href={base}>📚 Bookshelf Echo</a>
        <p class="tagline">Reading the day’s news from the shelf</p>
        <nav>
          <a href={base}>Latest</a>
          <a href={`${base}archive/`}>Archive</a>
          <a href={`${base}books/`}>Books</a>
        </nav>
      </header>
      <slot />
      <footer>
        <a class="dash-link" href={`${base}dashboard/`}>📊 System health — queue depth, LLM spend, DLQ</a><br />
        Auto-generated by the <a href="https://github.com/nplus-father/bookshelf-echo">bookshelf-echo</a> pipeline.
      </footer>
    </main>
  </body>
</html>
